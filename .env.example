## Server
PORT=3000
NODE_ENV=development

## Auth
# Generate a long random string for production (keep it secret!)
JWT_SECRET=replace_me_with_a_strong_secret

# If true, allows /api/auth/register even after setup (not recommended for SaaS)
ALLOW_PUBLIC_REGISTER=false

## PostgreSQL
# Option A (recommended): one URL
DATABASE_URL=postgres://postgres:password@localhost:5432/horseclub

# Option B: separate fields (used if DATABASE_URL is empty)
PGHOST=localhost
PGPORT=5432
PGDATABASE=horseclub
PGUSER=postgres
PGPASSWORD=password
